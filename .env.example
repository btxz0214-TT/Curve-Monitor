# Copy to .env for local dev (never commit .env).

# AI Builder Student Portal (local). Deployed apps use injected AI_BUILDER_TOKEN.
SUPER_MIND_API_KEY=

# Optional: if set, POST /run-scan requires header X-Run-Scan-Secret (same value).
# GitHub Actions weekly workflow uses the same secret if you add it there.
# RUN_SCAN_SECRET=

# Weekly email: configure Resend in GitHub → Settings → Secrets (see .github/workflows/weekly-radar-digest.yml).
