# Copy to .env and fill in values (never commit .env).

# Scan (AI Builder Student Portal)
SUPER_MIND_API_KEY=

# Weekly digest: caller must send header X-Cron-Secret matching this value.
CRON_SECRET=

# Email via Resend (recommended)
RESEND_API_KEY=
WEEKLY_DIGEST_TO=
# Optional; default is Resend test sender
# RESEND_FROM=Radar <onboarding@resend.dev>

# Automatic weekly digest inside the running server (no GitHub/cron-job.org)
# WEEKLY_DIGEST_SCHEDULE=true
# Optional UTC slot (default Monday 09:00)
# WEEKLY_DIGEST_WEEKDAY=0
# WEEKLY_DIGEST_UTC_HOUR=9
# WEEKLY_DIGEST_UTC_MINUTE=0
